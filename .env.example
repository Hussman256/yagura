# ── Yagura environment ────────────────────────────────────────────────
# Copy to .env and fill in. Everything is prefixed YAGURA_ so nothing
# collides when co-hosted with other services.

# Chain access ─────────────────────────────────────────────────────────
# Hiro Stacks Blockchain API. The public endpoint works without a key at
# ~50 req/min; set an API key (free at platform.hiro.so) to raise limits.
YAGURA_HIRO_API_BASE=https://api.hiro.so
YAGURA_HIRO_API_KEY=

# BNS V2 indexer API (by Strata Labs, backs bns-v2-sdk). Used as the
# primary read path for name/namespace/address lookups.
YAGURA_BNSV2_API_BASE=https://api.bnsv2.com

# Database ─────────────────────────────────────────────────────────────
# Postgres connection string, e.g. postgres://user:pass@host:5432/yagura
# Leave empty for local dev: the worker falls back to an embedded PGlite
# database (real Postgres, in-process) at ./data/yagura-dev.
# Also accepts pglite://<path> and pglite://memory explicitly.
# Note: the WEB app needs a real postgres:// URL (PGlite can't run inside
# Next's bundled server); without one it runs in no-database mode.
YAGURA_DATABASE_URL=

# Worker ───────────────────────────────────────────────────────────────
YAGURA_POLL_INTERVAL_MINUTES=10
# From @BotFather. Leave empty to run without Telegram (bot + delivery off).
YAGURA_TELEGRAM_BOT_TOKEN=
# Bot username (without @) — used by the web app for t.me deep links.
YAGURA_TELEGRAM_BOT_USERNAME=

# Email — pluggable provider: 'resend' for real delivery, 'console' (the
# default) logs outbound mail to stdout, which is perfect for local dev.
YAGURA_EMAIL_PROVIDER=console
YAGURA_RESEND_API_KEY=
YAGURA_EMAIL_FROM="Yagura <alerts@example.com>"

# Web ──────────────────────────────────────────────────────────────────
# Public base URL of the web app; used to build renewal/unsubscribe links
# inside alert messages.
YAGURA_WEB_BASE_URL=http://localhost:3000
